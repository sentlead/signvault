generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── NextAuth Required Models ────────────────────────────────────────────────
// These models are required by @auth/prisma-adapter for NextAuth v5 to work.
// They store OAuth account links, login sessions, and magic link tokens.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  // Each account belongs to one user
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A user can only link one account per provider
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Used for magic link email verification tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ───────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  emailVerified DateTime?
  image         String?   // Used by NextAuth for OAuth profile picture
  createdAt     DateTime  @default(now())

  // Subscription / billing
  plan                 String    @default("free")       // "free" | "pro" | "business"
  billingInterval      String?                           // "monthly" | "yearly"
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  subscriptionStatus   String?   @default("inactive")   // "active" | "past_due" | "canceled" | "inactive"
  currentPeriodEnd     DateTime?

  // Relations
  accounts        Account[]
  sessions        Session[]
  documents       Document[]
  savedSignatures SavedSignature[]
  usageRecords    UsageRecord[]
  templates       Template[]
  bulkSends       BulkSend[]
}

// Tracks how many documents a user has created each calendar month
model UsageRecord {
  id               String @id @default(cuid())
  userId           String
  period           String // "YYYY-MM"
  documentsCreated Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
}

model Document {
  id            String    @id @default(cuid())
  name          String
  ownerId       String
  fileUrl       String
  signedFileUrl String?
  // Status can be: draft | awaiting_signatures | completed | expired
  status        String    @default("draft")
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  // Sent timestamp and expiry/reminder settings (populated when doc is sent)
  sentAt            DateTime?  // when status changed to awaiting_signatures
  expiresAt         DateTime?  // null = never expires; set based on plan at send time
  reminderEnabled   Boolean   @default(true)
  reminderInterval  Int       @default(3)  // days between auto-reminders
  lastReminderAt    DateTime?              // last time cron sent an auto-reminder

  // Bulk send linkage — set when this document was created as part of a bulk batch
  bulkSendId    String?
  bulkSend      BulkSend? @relation(fields: [bulkSendId], references: [id])

  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  signers         Signer[]
  signatureFields SignatureField[]
  auditLogs       AuditLog[]
}

model Signer {
  id         String    @id @default(cuid())
  documentId String
  name       String
  email      String
  // Unique token used in the signing URL sent to the signer
  token      String    @unique @default(cuid())
  // Status can be: pending | signed
  status     String    @default("pending")
  signedAt   DateTime?
  signedIp   String?
  // Signing order — 0 = first to sign, 1 = second, etc.
  // Signers with the same order value are emailed simultaneously.
  order      Int       @default(0)

  document Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fields   SignatureField[]
}

model SignatureField {
  id         String  @id @default(cuid())
  documentId String
  signerId   String?
  // Type can be: signature | date | text | initials
  type       String
  pageNumber Int
  x          Float
  y          Float
  width      Float
  height     Float
  value      String?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signer   Signer?  @relation(fields: [signerId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  documentId String
  action     String
  actorEmail String
  ipAddress  String?
  timestamp  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

// A reusable document template — stores a PDF and its pre-placed field layout
// so the user doesn't have to drag out fields every time for the same doc type.
model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  fileUrl     String                   // the PDF this template was built from
  // JSON string: TemplateField[] — positions/types/signerRoleIndex for each field
  fields      String   @default("[]")
  // JSON string: SignerRole[] — role name for each signer slot, e.g. [{ "role": "Client" }]
  signerRoles String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

// A bulk-send batch — one record per "send to N recipients" action
// Each recipient gets their own Document record linked back here via bulkSendId.
model BulkSend {
  id           String   @id @default(cuid())
  ownerId      String
  // Human-readable name for this batch (shown on the bulk send dashboard)
  name         String
  // Snapshot of the template name at send time (kept even if template is deleted)
  templateName String
  // Total number of documents created in this batch
  totalCount   Int      @default(0)
  createdAt    DateTime @default(now())

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  documents Document[]
}

// Stores user's saved signature images (base64 PNG data) for reuse
model SavedSignature {
  id        String   @id @default(cuid())
  userId    String
  imageData String
  label     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
